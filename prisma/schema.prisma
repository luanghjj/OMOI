// OMOI Cafe Reservation System — Prisma Schema
// PostgreSQL on Supabase

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ───────────────────────────────────────────

enum Zone {
  WINDOW
  OUTDOOR
  QUIET
  WORKSPACE
  BAR
}

enum TableStatus {
  EMPTY
  BOOKED
  SEATED
  CLEANING
}

enum BookingStatus {
  PENDING
  CONFIRMED
  SEATED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum WaitlistStatus {
  WAITING
  NOTIFIED
  BOOKED
  EXPIRED
}

enum StaffRole {
  ADMIN
  STAFF
}

enum DiscountType {
  PERCENT
  FIXED
}

// ─── MODELS ──────────────────────────────────────────

model Table {
  id              String      @id @default(cuid())
  number          Int         @unique
  name            String
  zone            Zone
  capacity        Int
  hasOutlet       Boolean     @default(false)
  hasNaturalLight Boolean     @default(false)
  photoUrl        String?
  isActive        Boolean     @default(true)
  status          TableStatus @default(EMPTY)
  positionX       Float       // 0-100 percentage for floor map
  positionY       Float       // 0-100 percentage for floor map

  bookings      Booking[]
  bookingTables BookingTable[]

  @@map("tables")
}

model Booking {
  id            String        @id @default(cuid())
  bookingCode   String        @unique
  customerId    String?
  tableId       String?
  date          DateTime      @db.Date
  startTime     String        // HH:mm format
  endTime       String        // HH:mm format
  guestCount    Int
  status        BookingStatus @default(PENDING)
  depositAmount Int           @default(0)
  depositPaid   Boolean       @default(false)
  specialNote   String?
  guestName     String
  guestPhone    String
  guestEmail    String?
  staffId       String?
  createdAt     DateTime      @default(now())

  table     Table?     @relation(fields: [tableId], references: [id])
  customer  Customer?  @relation(fields: [customerId], references: [id])
  staff     Staff?     @relation(fields: [staffId], references: [id])
  preOrders PreOrder[]
  assignedTables BookingTable[]
  review    Review?

  @@map("bookings")
}

model BookingTable {
  id        String   @id @default(cuid())
  bookingId String
  tableId   String
  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  table   Table   @relation(fields: [tableId], references: [id])

  @@unique([bookingId, tableId])
  @@map("booking_tables")
}

model Customer {
  id            String   @id @default(cuid())
  name          String
  phone         String   @unique
  email         String?  @unique
  passwordHash  String?
  loyaltyPoints Int      @default(0)
  preferredZone Zone?
  createdAt     DateTime @default(now())

  bookings Booking[]
  reviews  Review[]

  @@map("customers")
}

model MenuItem {
  id          String  @id @default(cuid())
  name        String
  nameEn      String?
  category    String
  price       Int     // Price in VND
  photoUrl    String?
  isAvailable Boolean @default(true)

  preOrders PreOrder[]

  @@map("menu_items")
}

model PreOrder {
  id         String @id @default(cuid())
  bookingId  String
  menuItemId String
  quantity   Int
  note       String?

  booking  Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@map("pre_orders")
}

model Waitlist {
  id          String         @id @default(cuid())
  name        String
  phone       String
  desiredDate DateTime       @db.Date
  desiredTime String
  guestCount  Int
  zone        Zone?
  status      WaitlistStatus @default(WAITING)
  createdAt   DateTime       @default(now())

  @@map("waitlist")
}

model Staff {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         StaffRole @default(STAFF)
  assignedZone Zone?

  bookings Booking[]

  @@map("staff")
}

model PromoCode {
  id            String       @id @default(cuid())
  code          String       @unique
  discountType  DiscountType
  discountValue Int
  minGuests     Int          @default(1)
  validFrom     DateTime
  validTo       DateTime
  usageLimit    Int          @default(0)
  usageCount    Int          @default(0)
  isActive      Boolean      @default(true)

  @@map("promo_codes")
}

model AppSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

model Review {
  id         String   @id @default(cuid())
  bookingId  String   @unique
  customerId String
  rating     Int      // 1-5
  comment    String?
  createdAt  DateTime @default(now())

  booking  Booking  @relation(fields: [bookingId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])

  @@map("reviews")
}
